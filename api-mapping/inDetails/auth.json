{
  "module": "Authentication",
  "basePath": "/api/auth",
  "description": "User registration, login, email verification, password reset, and profile management",
  "authentication": {
    "type": "Bearer JWT",
    "header": "Authorization: Bearer <token>",
    "tokenPayload": { "id": "number", "role": "string" },
    "expiresIn": "1 day",
    "storageKeys": {
      "admin": "dealora-auth-token",
      "storefront": "dealora_token"
    }
  },
  "endpoints": [
    {
      "name": "Register",
      "method": "POST",
      "path": "/api/auth/register",
      "auth": false,
      "description": "Register a new user account",
      "frontendUsage": {
        "usedBy": "RegisterPage.jsx (Storefront)",
        "frontendDescription": "First step of registration - sends user details to create account, then OTP is sent to email"
      },
      "request": {
        "body": {
          "name": { "type": "string", "required": true, "example": "Ahmed Ali" },
          "email": { "type": "string", "required": true, "example": "ahmed@example.com" },
          "password": { "type": "string", "required": true, "example": "password123" },
          "phone": { "type": "string", "required": true, "example": "01012345678" },
          "gender": { "type": "string", "required": false, "example": "male" }
        }
      },
      "response": {
        "success": {
          "statusCode": 201,
          "body": {
            "message": { "type": "string", "example": "Registration successful" },
            "userId": { "type": "number", "example": 1 }
          }
        },
        "error": {
          "statusCode": 400,
          "body": { "message": "Email already exists" }
        }
      },
      "frontendDisplay": "Shows success toast and navigates to OTP verification step"
    },
    {
      "name": "Verify Email",
      "method": "POST",
      "path": "/api/auth/verify-email",
      "auth": false,
      "description": "Verify email address with OTP code",
      "frontendUsage": {
        "usedBy": "RegisterPage.jsx (Storefront)",
        "frontendDescription": "Second step of registration - user enters 6-digit OTP received via email"
      },
      "request": {
        "body": {
          "email": { "type": "string", "required": true, "example": "ahmed@example.com" },
          "otp": { "type": "string", "required": true, "example": "123456" }
        }
      },
      "response": {
        "success": {
          "statusCode": 200,
          "body": { "message": "Email verified successfully" }
        },
        "error": {
          "statusCode": 400,
          "body": { "message": "Invalid or expired OTP" }
        }
      },
      "frontendDisplay": "Shows success toast, completes registration, navigates to login page"
    },
    {
      "name": "Resend OTP",
      "method": "POST",
      "path": "/api/auth/resend-otp",
      "auth": false,
      "description": "Resend verification OTP to email",
      "frontendUsage": {
        "usedBy": "Storefront",
        "frontendDescription": "Triggered when user clicks 'Resend Code' during email verification"
      },
      "request": {
        "body": {
          "email": { "type": "string", "required": true, "example": "ahmed@example.com" }
        }
      },
      "response": {
        "success": {
          "statusCode": 200,
          "body": { "message": "OTP resent successfully" }
        }
      },
      "frontendDisplay": "Shows confirmation toast that OTP was resent"
    },
    {
      "name": "Forgot Password",
      "method": "POST",
      "path": "/api/auth/forgot-password",
      "auth": false,
      "description": "Request password reset OTP",
      "frontendUsage": {
        "usedBy": "Storefront",
        "frontendDescription": "User submits email to receive password reset code"
      },
      "request": {
        "body": {
          "email": { "type": "string", "required": true, "example": "ahmed@example.com" }
        }
      },
      "response": {
        "success": {
          "statusCode": 200,
          "body": { "message": "Password reset OTP sent" }
        }
      },
      "frontendDisplay": "Shows success message, navigates to OTP input screen"
    },
    {
      "name": "Reset Password",
      "method": "POST",
      "path": "/api/auth/reset-password",
      "auth": false,
      "description": "Reset password using OTP",
      "frontendUsage": {
        "usedBy": "Storefront",
        "frontendDescription": "User enters OTP and new password to complete password reset"
      },
      "request": {
        "body": {
          "email": { "type": "string", "required": true, "example": "ahmed@example.com" },
          "otp": { "type": "string", "required": true, "example": "123456" },
          "newPassword": { "type": "string", "required": true, "example": "newPass123" }
        }
      },
      "response": {
        "success": {
          "statusCode": 200,
          "body": { "message": "Password reset successfully" }
        }
      },
      "frontendDisplay": "Shows success toast, navigates to login page"
    },
    {
      "name": "Login",
      "method": "POST",
      "path": "/api/auth/login",
      "auth": false,
      "description": "Login with email and password",
      "frontendUsage": {
        "usedBy": "LoginPage.jsx (Storefront), AuthContext.jsx (Admin Dashboard)",
        "frontendDescription": "Authenticates user and returns JWT token. Admin users navigate to /dashboard, regular users to /home. Token stored in localStorage.",
        "currentStatus": "Storefront uses mock login (commented-out real API). Admin uses localStorage-based auth."
      },
      "request": {
        "body": {
          "email": { "type": "string", "required": true, "example": "ahmed@example.com" },
          "password": { "type": "string", "required": true, "example": "password123" }
        }
      },
      "response": {
        "success": {
          "statusCode": 200,
          "body": {
            "message": { "type": "string", "example": "Login successful" },
            "token": { "type": "string", "example": "eyJhbGciOiJIUzI1NiIs..." },
            "user": {
              "id": { "type": "number", "example": 1 },
              "name": { "type": "string", "example": "Ahmed Ali" },
              "email": { "type": "string", "example": "ahmed@example.com" },
              "role": { "type": "string", "enum": ["super_admin", "store_manager", "customer"], "example": "customer" }
            }
          }
        },
        "error": {
          "statusCode": 401,
          "body": { "message": "Invalid email or password" }
        }
      },
      "frontendDisplay": "Shows user info in sidebar/header, stores token for subsequent API calls, redirects based on role"
    },
    {
      "name": "Get Profile",
      "method": "GET",
      "path": "/api/auth/profile",
      "auth": true,
      "roles": ["super_admin", "store_manager", "customer"],
      "description": "Get current user's profile information",
      "frontendUsage": {
        "usedBy": "Storefront Profile Page",
        "frontendDescription": "Fetches and displays user profile data including name, email, phone, gender, address info, and avatar"
      },
      "request": {
        "headers": {
          "Authorization": { "type": "string", "required": true, "example": "Bearer <token>" }
        }
      },
      "response": {
        "success": {
          "statusCode": 200,
          "body": {
            "id": { "type": "number", "example": 1 },
            "name": { "type": "string", "example": "Ahmed Ali" },
            "email": { "type": "string", "example": "ahmed@example.com" },
            "phone": { "type": "string", "example": "01012345678" },
            "second_phone": { "type": "string", "nullable": true, "example": "01098765432" },
            "gender": { "type": "string", "nullable": true, "example": "male" },
            "photo_url": { "type": "string", "nullable": true, "example": "https://example.com/avatar.jpg" },
            "role": { "type": "string", "example": "customer" },
            "country": { "type": "string", "nullable": true, "example": "Egypt" },
            "governorate": { "type": "string", "nullable": true, "example": "Cairo" },
            "zip_code": { "type": "string", "nullable": true, "example": "11511" },
            "created_at": { "type": "string", "format": "datetime", "example": "2024-01-15T10:30:00Z" }
          }
        }
      },
      "frontendDisplay": "Populates profile form fields, displays avatar in sidebar/header, shows user info on profile page"
    },
    {
      "name": "Update Profile",
      "method": "PUT",
      "path": "/api/auth/profile",
      "auth": true,
      "roles": ["super_admin", "store_manager", "customer"],
      "description": "Update current user's profile information",
      "frontendUsage": {
        "usedBy": "Storefront Profile Page",
        "frontendDescription": "User edits profile fields (name, phone, gender, address, avatar). Updated data reflected in sidebar and profile page."
      },
      "request": {
        "headers": {
          "Authorization": { "type": "string", "required": true }
        },
        "body": {
          "name": { "type": "string", "required": false },
          "phone": { "type": "string", "required": false },
          "second_phone": { "type": "string", "required": false },
          "gender": { "type": "string", "required": false },
          "photo_url": { "type": "string", "required": false },
          "country": { "type": "string", "required": false },
          "governorate": { "type": "string", "required": false },
          "zip_code": { "type": "string", "required": false }
        }
      },
      "response": {
        "success": {
          "statusCode": 200,
          "body": { "message": "Profile updated successfully" }
        }
      },
      "frontendDisplay": "Shows success toast, updates displayed profile info, updates avatar in sidebar"
    }
  ]
}
