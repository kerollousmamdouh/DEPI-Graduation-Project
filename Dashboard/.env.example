# انسخ هذا الملف باسم .env وعدّل القيم عند ربط الداشبورد بالباك اند الحقيقي

# رابط الـ API الخاص بالباك اند (اتركه فارغًا للاستمرار في وضع البيانات التجريبية)
VITE_API_BASE_URL=

# رابط الموقع الرئيسي/المتجر (الـ Homepage) اللي هيفتحه زرار "عرض المتجر" بالقائمة الجانبية
VITE_STOREFRONT_URL=https://your-storefront-domain.com
